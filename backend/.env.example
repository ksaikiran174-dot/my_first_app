# Copy to .env and fill in values. Never commit .env.

# development | production
ENVIRONMENT=development

# Required in production (min 32 characters). Recommended everywhere.
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# Postgres (production) or omit to use sqlite:///./local_dev.db in development
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Comma-separated browser origins allowed to call this API (no spaces)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Required for POST /users/signup when signup is enabled
ADMIN_COMPANY_CODE=your-strong-private-code

# In production, signup is OFF unless you set true (bootstrap first admin, then set false)
# ENABLE_PUBLIC_SIGNUP=false

# Optional
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_ALGORITHM=HS256
# DB_POOL_RECYCLE=280
# In production, /docs is off unless you set:
# ENABLE_OPENAPI_DOCS=true
